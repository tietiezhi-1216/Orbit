{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tietiezhi.dev/schemas/automation/v1/workflow.schema.json",
  "title": "Tietiezhi Automation Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "description",
    "revision",
    "nodes",
    "edges",
    "settings",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "maxLength": 500 },
    "revision": { "type": "integer", "minimum": 0 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "settings": { "$ref": "#/$defs/settings" },
    "createdAt": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "binding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "literal" },
            "value": true
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path"],
          "properties": {
            "kind": { "const": "triggerInput" },
            "path": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "nodeId", "path"],
          "properties": {
            "kind": { "const": "nodeOutput" },
            "nodeId": { "type": "string", "minLength": 1 },
            "path": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "credentialId"],
          "properties": {
            "kind": { "const": "secretRef" },
            "credentialId": { "type": "string", "minLength": 1 },
            "key": { "type": "string" }
          }
        }
      ]
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "typeVersion",
        "name",
        "position",
        "disabled",
        "config",
        "inputs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 80 },
        "type": { "type": "string", "minLength": 1, "maxLength": 100 },
        "typeVersion": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "position": { "$ref": "#/$defs/position" },
        "disabled": { "type": "boolean" },
        "config": { "type": "object" },
        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/binding" }
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sourceNodeId", "sourcePort", "targetNodeId", "targetPort"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 120 },
        "sourceNodeId": { "type": "string", "minLength": 1 },
        "sourcePort": { "type": "string", "minLength": 1 },
        "targetNodeId": { "type": "string", "minLength": 1 },
        "targetPort": { "type": "string", "minLength": 1 }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timezone", "maxDurationMs", "maxConcurrency", "onMissedSchedule"],
      "properties": {
        "timezone": { "type": "string", "minLength": 1 },
        "maxDurationMs": { "type": "integer", "minimum": 1000, "maximum": 86400000 },
        "maxConcurrency": { "type": "integer", "minimum": 1, "maximum": 64 },
        "onMissedSchedule": { "enum": ["skip", "runLatest"] }
      }
    }
  }
}
