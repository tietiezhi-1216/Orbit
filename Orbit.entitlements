<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened Runtime (required for notarization) blocks microphone access
	     unless this entitlement is present. Orbit records via AVAudioEngine. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- The global hotkey (CGEventTap) and the synthesized ⌘V paste are gated by
	     the Accessibility TCC permission, NOT by an entitlement, so nothing extra
	     is needed here for them. Keep this file minimal. -->
</dict>
</plist>
