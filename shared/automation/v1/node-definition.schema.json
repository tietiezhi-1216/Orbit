{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tietiezhi.dev/schemas/automation/v1/node-definition.schema.json",
  "title": "Tietiezhi Automation Node Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "version",
    "category",
    "title",
    "description",
    "configSchema",
    "inputSchema",
    "outputSchema",
    "capabilities",
    "executionMode"
  ],
  "properties": {
    "type": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": { "type": "integer", "minimum": 1 },
    "category": {
      "enum": ["trigger", "ai", "tool", "transform", "logic", "human", "output"]
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "maxLength": 300 },
    "configSchema": { "type": "object" },
    "inputSchema": { "type": "object" },
    "outputSchema": { "type": "object" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "executionMode": { "enum": ["local", "remote", "either"] }
  }
}
